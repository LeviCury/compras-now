# =============================================================================
# Compras Now Executivo - .env de exemplo
# =============================================================================
# Copie esse arquivo para `.env` (na raiz do projeto e no servidor de producao
# em C:\apps\compras-now\.env) e preencha com valores reais.
#
# NUNCA commite o .env real - ele esta no .gitignore.

# --- GitHub (datalake) ---
# Personal Access Token (fine-grained) com permissao "Contents: Read" no repo
# de dados. Usado pelas rotas /api/* para ler snapshots, history/ e screenshots/.
# Aceita ambos os nomes: GITHUB_TOKEN ou GITHUB_PAT.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repositorio que armazena os dados (formato owner/repo).
GITHUB_REPO=LeviCury/compras-now

# Branch onde os arquivos vivem.
GITHUB_BRANCH=main

# (Opcional) Subpasta raiz dentro do repo onde estao os arquivos de dados.
# Default: "data"
GITHUB_DATA_PATH=data

# --- Servidor ---
# Porta HTTP local. Em dev usa 8080; em producao na VM, 80.
PORT=8080

# --- Autenticacao Microsoft Entra ID ---
# App registrado em Azure Portal -> Microsoft Entra ID -> App registrations.
# Pegue Tenant ID, Client ID e Client Secret da app registration.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=xxxx~xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Callback completo. DEVE estar cadastrado em App Registration -> Authentication.
# Dev local:  http://localhost:8080/auth/callback
# Producao com HTTPS: https://comprasnow.minervafoods.com/auth/callback
AZURE_REDIRECT_URI=http://localhost:8080/auth/callback

# Segredo para assinar cookies de sessao. Gere uma string aleatoria longa
# (64+ caracteres). Em producao, MANTENHA estavel ou todas as sessoes
# existentes serao invalidadas a cada restart.
# Para gerar uma: `node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"`
SESSION_SECRET=substitua-por-uma-string-aleatoria-longa-de-64-chars-ou-mais

# Bypass de auth (1=desliga login, 0=ativa). Use 1 SOMENTE em ambientes onde
# HTTPS ainda nao esta disponivel - o Entra ID rejeita redirect HTTP em
# dominios diferentes de localhost. Em desenvolvimento local, deixe 0.
AUTH_DISABLED=0
