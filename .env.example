# --- Variaveis da API serverless (Vercel) ---
# Personal Access Token (fine-grained) com permissao "Contents: Read" no repo de dados.
# Usado pelos endpoints em api/ para ler latest.json, history/ e screenshots/.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repositorio que armazena os dados (formato owner/repo).
# Pode ser o mesmo repo do dashboard ou um separado dedicado a dados.
GITHUB_REPO=LeviCury/compras-now

# Branch onde os arquivos vivem.
GITHUB_BRANCH=main

# (Opcional) Subpasta raiz dentro do repo onde estao os arquivos de dados.
# Default: "data"
GITHUB_DATA_PATH=data
