  "version": "1.0.0",
  "description": "Compras Now - Painel Executivo do CEO (Minerva Foods)",
  "author": "Levi Cury",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
