# ============================================================
# Configuracao do RPA Compras Now
# Chamado pelo Power Automate Desktop (subfluxo ReportExport)
# ============================================================

# --- GitHub (push do snapshot) ---
# Fine-grained PAT com permissoes "Contents: Read and write" no repo.
# Crie em https://github.com/settings/personal-access-tokens
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repositorio destino (formato owner/repo).
GITHUB_REPO=LeviCury/compras-now

# Branch onde os arquivos serao gravados.
GITHUB_BRANCH=main

# Subpasta dentro do repo onde os arquivos vao viver (default: data)
GITHUB_DATA_PATH=data

# Autor dos commits gerados pelo RPA.
# IMPORTANTE: precisa ser um email RECONHECIDO pelo GitHub e vinculado a uma
# conta com acesso ao repo, senao o Vercel bloqueia o deploy
# ("commit author email not valid"). Recomendado: use o email no-reply do
# proprio dono do PAT, no formato:
#   <id_numerico>+<login>@users.noreply.github.com
# Voce ve esse email em https://github.com/settings/emails (secao
# "Keep my email addresses private").
GIT_AUTHOR_NAME=Levi Cury
GIT_AUTHOR_EMAIL=192823885+[email protected]

# --- Pastas locais ---
# Pasta onde o Power Automate salva o Excel e a print (entrada do pipeline).
# Mesma pasta do priStrExecutionFolderPath do flow do PAD.
LOCAL_DOWNLOAD_DIR=C:\RPA Compras Now

# Nome FIXO do Excel exportado pelo flow (priStrReportFilePath sem o diretorio).
EXCEL_FILENAME=Relatorio-Compras-Now.xls

# Nome FIXO da print capturada pelo flow (priStrPrintReportFilePath sem o diretorio).
SCREENSHOT_FILENAME=Print-Relatorio-Compras-Now.png
